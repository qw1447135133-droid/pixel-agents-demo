
&lt;!doctype html&gt;
&lt;html lang="en"&gt;
  &lt;head&gt;
    &lt;meta charset="UTF-8" /&gt;
    &lt;link rel="icon" type="image/svg+xml" href="/vite.svg" /&gt;
    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0" /&gt;
    &lt;title&gt;Pixel Agents - Standalone&lt;/title&gt;
    &lt;script type="module" crossorigin src="./assets/index-BTCFuRMK.js"&gt;&lt;/script&gt;
    &lt;link rel="stylesheet" crossorigin href="./assets/index-C0_Jd-v0.css"&gt;
    &lt;style&gt;
      :root {
        --vscode-foreground: #cccccc;
        --pixel-bg: #1e1e1e;
        --pixel-border: #3c3c3c;
        --pixel-text: #cccccc;
        --pixel-text-dim: #858585;
        --pixel-btn-bg: #2d2d2d;
        --pixel-btn-disabled-opacity: 0.5;
        --pixel-accent: #007acc;
        --pixel-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
        --pixel-hint-bg: #007acc;
        --pixel-reset-text: #ff6b6b;
        --pixel-danger-bg: #d32f2f;
        --pixel-vignette: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.4) 100%);
        --pixel-controls-z: 50;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body, #root { width: 100%; height: 100%; overflow: hidden; background: #1e1e1e; }
      #loading {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #1e1e1e;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        color: #ccc;
        font-family: system-ui, -apple-system, sans-serif;
      }
      #loading h1 { margin-bottom: 20px; font-size: 28px; }
      #loading .progress { width: 400px; height: 20px; background: #333; border-radius: 0; overflow: hidden; }
      #loading .bar { height: 100%; background: #007acc; width: 0%; transition: width 0.3s; }
      #loading .text { margin-top: 15px; font-size: 18px; }
    &lt;/style&gt;
  &lt;/head&gt;
  &lt;body&gt;
    &lt;div id="loading"&gt;
      &lt;h1&gt;Pixel Agents&lt;/h1&gt;
      &lt;div class="progress"&gt;&lt;div class="bar" id="progress-bar"&gt;&lt;/div&gt;&lt;/div&gt;
      &lt;div class="text" id="loading-text"&gt;Loading furniture assets...&lt;/div&gt;
    &lt;/div&gt;
    &lt;div id="root"&gt;&lt;/div&gt;
    &lt;script&gt;
(function() {
  'use strict';

  window.acquireVsCodeApi = function() {
    return {
      postMessage: function(msg) {
        console.log('[Mock VS Code] postMessage:', msg);
      }
    };
  };

  window.addEventListener('message', function(e) {
    console.log('[Mock] Received message:', e.data);
  });

  const PNG_ALPHA_THRESHOLD = 16;

  function rgbaToHex(r, g, b, a) {
    if (a &lt; PNG_ALPHA_THRESHOLD) return '';
    var rgb = '#' + r.toString(16).padStart(2, '0') + g.toString(16).padStart(2, '0') + b.toString(16).padStart(2, '0').toUpperCase();
    if (a &gt;= 255) return rgb;
    return rgb + a.toString(16).padStart(2, '0').toUpperCase();
  }

  async function loadPngToSpriteData(url, width, height) {
    return new Promise(function(resolve, reject) {
      var img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = function() {
        var canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        var ctx = canvas.getContext('2d');
        if (!ctx) {
          reject(new Error('Could not get canvas context'));
          return;
        }
        ctx.imageSmoothingEnabled = false;
        ctx.drawImage(img, 0, 0, width, height);
        var imageData = ctx.getImageData(0, 0, width, height);
        var data = imageData.data;
        var sprite = [];
        for (var y = 0; y &lt; height; y++) {
          var row = [];
          for (var x = 0; x &lt; width; x++) {
            var pixelIndex = (y * width + x) * 4;
            var r = data[pixelIndex];
            var g = data[pixelIndex + 1];
            var b = data[pixelIndex + 2];
            var a = data[pixelIndex + 3];
            row.push(rgbaToHex(r, g, b, a));
          }
          sprite.push(row);
        }
        resolve(sprite);
      };
      img.onerror = reject;
      img.src = url;
    });
  }

  function flattenManifest(node, inherited) {
    if (node.type === 'asset') {
      var asset = node;
      var orientation = asset.orientation || inherited.orientation;
      var state = asset.state || inherited.state;
      var result = {
        id: asset.id,
        name: inherited.name,
        label: inherited.name,
        category: inherited.category,
        file: asset.file,
        width: asset.width,
        height: asset.height,
        footprintW: asset.footprintW,
        footprintH: asset.footprintH,
        isDesk: inherited.category === 'desks',
        canPlaceOnWalls: inherited.canPlaceOnWalls,
        canPlaceOnSurfaces: inherited.canPlaceOnSurfaces,
        backgroundTiles: inherited.backgroundTiles,
        groupId: inherited.groupId
      };
      if (orientation) result.orientation = orientation;
      if (state) result.state = state;
      if (asset.mirrorSide) result.mirrorSide = true;
      if (inherited.rotationScheme) result.rotationScheme = inherited.rotationScheme;
      if (inherited.animationGroup) result.animationGroup = inherited.animationGroup;
      if (asset.frame !== undefined) result.frame = asset.frame;
      return [result];
    }

    var group = node;
    var results = [];

    for (var i = 0; i &lt; group.members.length; i++) {
      var member = group.members[i];
      var childProps = {
        groupId: inherited.groupId,
        name: inherited.name,
        category: inherited.category,
        canPlaceOnWalls: inherited.canPlaceOnWalls,
        canPlaceOnSurfaces: inherited.canPlaceOnSurfaces,
        backgroundTiles: inherited.backgroundTiles
      };
      if (inherited.orientation) childProps.orientation = inherited.orientation;
      if (inherited.state) childProps.state = inherited.state;
      if (inherited.rotationScheme) childProps.rotationScheme = inherited.rotationScheme;
      if (inherited.animationGroup) childProps.animationGroup = inherited.animationGroup;

      if (group.groupType === 'rotation' &amp;&amp; group.rotationScheme) {
        childProps.rotationScheme = group.rotationScheme;
      }

      if (group.groupType === 'state') {
        if (group.orientation) {
          childProps.orientation = group.orientation;
        }
        if (group.state) {
          childProps.state = group.state;
        }
      }

      if (group.groupType === 'animation') {
        var orient = group.orientation || inherited.orientation || '';
        var state = group.state || inherited.state || '';
        childProps.animationGroup = (inherited.groupId + '_' + orient + '_' + state).toUpperCase();
        if (group.state) {
          childProps.state = group.state;
        }
      }

      if (group.orientation &amp;&amp; !childProps.orientation) {
        childProps.orientation = group.orientation;
      }

      var memberResults = flattenManifest(member, childProps);
      for (var j = 0; j &lt; memberResults.length; j++) {
        results.push(memberResults[j]);
      }
    }

    return results;
  }

  async function loadFurnitureAssets() {
    var catalog = [];
    var sprites = {};

    var furnitureTypes = [
      'BIN', 'BOOKSHELF', 'CACTUS', 'CLOCK', 'COFFEE', 'COFFEE_TABLE',
      'CUSHIONED_BENCH', 'CUSHIONED_CHAIR', 'DESK', 'DOUBLE_BOOKSHELF',
      'HANGING_PLANT', 'LARGE_PAINTING', 'LARGE_PLANT', 'PC', 'PLANT',
      'PLANT_2', 'POT', 'SMALL_PAINTING', 'SMALL_PAINTING_2', 'SMALL_TABLE',
      'SOFA', 'TABLE_FRONT', 'WHITEBOARD', 'WOODEN_BENCH', 'WOODEN_CHAIR'
    ];

    for (var i = 0; i &lt; furnitureTypes.length; i++) {
      var type = furnitureTypes[i];
      try {
        var manifestRes = await fetch('./assets/furniture/' + type + '/manifest.json');
        if (manifestRes.ok) {
          var manifest = await manifestRes.json();

          var inherited = {
            groupId: manifest.id,
            name: manifest.name,
            category: manifest.category,
            canPlaceOnWalls: manifest.canPlaceOnWalls,
            canPlaceOnSurfaces: manifest.canPlaceOnSurfaces,
            backgroundTiles: manifest.backgroundTiles
          };

          var assets;
          if (manifest.type === 'asset') {
            assets = [{
              id: manifest.id,
              name: manifest.name,
              label: manifest.name,
              category: manifest.category,
              file: manifest.file || (manifest.id + '.png'),
              width: manifest.width,
              height: manifest.height,
              footprintW: manifest.footprintW,
              footprintH: manifest.footprintH,
              isDesk: manifest.category === 'desks',
              canPlaceOnWalls: manifest.canPlaceOnWalls,
              canPlaceOnSurfaces: manifest.canPlaceOnSurfaces,
              backgroundTiles: manifest.backgroundTiles,
              groupId: manifest.id
            }];
          } else {
            if (manifest.rotationScheme) {
              inherited.rotationScheme = manifest.rotationScheme;
            }
            var rootGroup = {
              type: 'group',
              groupType: manifest.groupType,
              rotationScheme: manifest.rotationScheme,
              members: manifest.members
            };
            assets = flattenManifest(rootGroup, inherited);
          }

          for (var j = 0; j &lt; assets.length; j++) {
            var asset = assets[j];
            try {
              var spriteData = await loadPngToSpriteData(
                './assets/furniture/' + type + '/' + asset.file,
                asset.width,
                asset.height
              );
              sprites[asset.id] = spriteData;
              catalog.push(asset);
            } catch (e) {
              console.log('Could not load sprite for ' + type + '/' + asset.id + ':', e);
            }
          }
        }
      } catch (e) {
        console.log('Could not load manifest for ' + type + ':', e);
      }

      var progressBar = document.getElementById('progress-bar');
      var loadingText = document.getElementById('loading-text');
      if (progressBar) {
        progressBar.style.width = Math.round(((i + 1) / furnitureTypes.length) * 100) + '%';
      }
      if (loadingText) {
        loadingText.textContent = 'Loading: ' + type + '...';
      }
    }

    console.log('[Mock] Loaded ' + Object.keys(sprites).length + ' / ' + catalog.length + ' furniture assets');
    return { catalog: catalog, sprites: sprites };
  }

  async function loadCharacterSprites() {
    var characters = [];
    var CHAR_COUNT = 6;
    var CHAR_FRAME_H = 32;
    var CHAR_FRAME_W = 16;
    var CHAR_FRAMES_PER_ROW = 7;
    var CHARACTER_DIRECTIONS = ['down', 'up', 'right'];

    for (var ci = 0; ci &lt; CHAR_COUNT; ci++) {
      try {
        var fullSprite = await loadPngToSpriteData('./assets/characters/char_' + ci + '.png', 112, 96);

        var charData = { down: [], up: [], right: [] };

        for (var dirIdx = 0; dirIdx &lt; CHARACTER_DIRECTIONS.length; dirIdx++) {
          var dir = CHARACTER_DIRECTIONS[dirIdx];
          var rowOffsetY = dirIdx * CHAR_FRAME_H;
          var frames = [];

          for (var f = 0; f &lt; CHAR_FRAMES_PER_ROW; f++) {
            var frame = [];
            var frameOffsetX = f * CHAR_FRAME_W;

            for (var y = 0; y &lt; CHAR_FRAME_H; y++) {
              var row = [];
              for (var x = 0; x &lt; CHAR_FRAME_W; x++) {
                row.push(fullSprite[rowOffsetY + y][frameOffsetX + x]);
              }
              frame.push(row);
            }
            frames.push(frame);
          }
          charData[dir] = frames;
        }
        characters.push(charData);
      } catch (e) {
        console.log('Could not load character ' + ci + ':', e);
      }
    }

    return characters;
  }

  async function loadFloorTiles() {
    var sprites = [];
    var FLOOR_TILE_SIZE = 16;

    var fi = 0;
    while (true) {
      try {
        var spriteData = await loadPngToSpriteData('./assets/floors/floor_' + fi + '.png', FLOOR_TILE_SIZE, FLOOR_TILE_SIZE);
        sprites.push(spriteData);
        fi++;
      } catch {
        break;
      }
    }

    return sprites;
  }

  async function loadWallTiles() {
    var sets = [];
    var WALL_BITMASK_COUNT = 16;
    var WALL_GRID_COLS = 4;
    var WALL_PIECE_HEIGHT = 32;
    var WALL_PIECE_WIDTH = 16;

    var wi = 0;
    while (true) {
      try {
        var fullSprite = await loadPngToSpriteData('./assets/walls/wall_' + wi + '.png', 64, 128);
        var wallSet = [];

        for (var mask = 0; mask &lt; WALL_BITMASK_COUNT; mask++) {
          var ox = (mask % WALL_GRID_COLS) * WALL_PIECE_WIDTH;
          var oy = Math.floor(mask / WALL_GRID_COLS) * WALL_PIECE_HEIGHT;
          var sprite = [];

          for (var r = 0; r &lt; WALL_PIECE_HEIGHT; r++) {
            var row = [];
            for (var c = 0; c &lt; WALL_PIECE_WIDTH; c++) {
              row.push(fullSprite[oy + r][ox + c]);
            }
            sprite.push(row);
          }
          wallSet.push(sprite);
        }
        sets.push(wallSet);
        wi++;
      } catch {
        break;
      }
    }

    return sets;
  }

  async function init() {
    try {
      var loadingText = document.getElementById('loading-text');
      if (loadingText) {
        loadingText.textContent = 'Loading character sprites...';
      }

      var characters = await loadCharacterSprites();
      window.postMessage({
        type: 'characterSpritesLoaded',
        characters: characters
      }, '*');

      if (loadingText) {
        loadingText.textContent = 'Loading floor tiles...';
      }

      var floorTiles = await loadFloorTiles();
      window.postMessage({
        type: 'floorTilesLoaded',
        sprites: floorTiles
      }, '*');

      if (loadingText) {
        loadingText.textContent = 'Loading wall tiles...';
      }

      var wallTiles = await loadWallTiles();
      window.postMessage({
        type: 'wallTilesLoaded',
        sets: wallTiles
      }, '*');

      if (loadingText) {
        loadingText.textContent = 'Loading furniture assets...';
      }

      var assets = await loadFurnitureAssets();
      window.postMessage({
        type: 'furnitureAssetsLoaded',
        catalog: assets.catalog,
        sprites: assets.sprites
      }, '*');

      if (loadingText) {
        loadingText.textContent = 'Loading default layout...';
      }

      var layoutRes = await fetch('./assets/default-layout-1.json');
      var layout = await layoutRes.json();

      setTimeout(function() {
        var loading = document.getElementById('loading');
        if (loading) {
          loading.style.display = 'none';
        }
      }, 300);

      window.postMessage({ type: 'layoutLoaded', layout: layout }, '*');
      window.postMessage({ type: 'settingsLoaded', soundEnabled: true }, '*');

      setTimeout(function() {
        window.postMessage({
          type: 'existingAgents',
          agents: [1, 2],
          agentMeta: {
            1: { palette: 0, hueShift: 0, seatId: null },
            2: { palette: 1, hueShift: 0, seatId: null }
          },
          folderNames: { 1: 'pixel-agents', 2: 'pixel-agents' }
        }, '*');

        setTimeout(function() {
          window.postMessage({
            type: 'agentCreated',
            id: 1,
            folderName: 'pixel-agents'
          }, '*');

          window.postMessage({
            type: 'agentToolStart',
            id: 1,
            toolId: 'tool1',
            status: 'Writing file'
          }, '*');
        }, 500);
      }, 300);
    } catch (err) {
      console.error('[Demo] Init failed:', err);
      var loadingText = document.getElementById('loading-text');
      if (loadingText) {
        loadingText.textContent = 'Error loading assets - check console';
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
    &lt;/script&gt;
  &lt;/body&gt;
&lt;/html&gt;

